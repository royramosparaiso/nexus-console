# Nexus Console — example env vars
# Copy to .env and adjust. All backend vars are prefixed CONSOLE_.

# Environment: local | dev | prod
CONSOLE_ENV=local

# Database (Postgres 17+, asyncpg driver)
CONSOLE_DATABASE_URL=postgresql+asyncpg://console:console@localhost:5432/nexus_console

# Redis (7+)
CONSOLE_REDIS_URL=redis://localhost:6379/0

# Console signing keys (Ed25519). Generated on first run if missing.
CONSOLE_CONSOLE_PRIVATE_KEY_PATH=./.console_keys/console_ed25519.pem
CONSOLE_CONSOLE_PUBLIC_KEY_PATH=./.console_keys/console_ed25519.pub
CONSOLE_JWT_ALGORITHM=EdDSA
CONSOLE_JWT_TTL_SECONDS=60

# Local single-tenant bootstrap
CONSOLE_LOCAL_MODE=true
CONSOLE_LOCAL_PLATFORM_URL=http://platform:7100

# CORS
CONSOLE_CORS_ORIGINS=["http://localhost:7000","http://localhost:5173"]

# --- Voicebox (optional local-first voice sidecar) -------------------------
# Voicebox (https://github.com/jamiepine/voicebox) is a SEPARATE local process
# exposing a REST API + HTTP MCP server for TTS/STT. Nexus never bundles it and
# never uploads audio — it only talks to the base URL you set here.
CONSOLE_VOICEBOX_ENABLED=false
CONSOLE_VOICEBOX_BASE_URL=http://localhost:5111
# Optional — only if you put Voicebox behind auth. Held server-side, never
# returned by the API.
# CONSOLE_VOICEBOX_API_KEY=
CONSOLE_VOICEBOX_MCP_PATH=/mcp
# Voice cloning is OFF unless you explicitly assert you own the voice and
# consent to clone it. Nexus performs no cloning itself.
CONSOLE_VOICEBOX_VOICE_CLONING_CONSENT=false

# --- Integration adapters (Ecosystem → Integrations) -----------------------
# The integration adapter layer stores connection profiles that reference
# secrets by ENVIRONMENT-VARIABLE NAME only. There is no secret vault in this
# repo, so values are NEVER persisted to the database and NEVER returned by the
# API — they are read from the process environment at probe/resolve time.
# Set only the vars for the providers you actually use. These are unprefixed
# (they are provider-native names), unlike the CONSOLE_* settings above.
#
# LLMs / open models (OpenAI-compatible where possible):
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
# MISTRAL_API_KEY=
# DEEPSEEK_API_KEY=
# GROQ_API_KEY=
# TOGETHER_API_KEY=
# COHERE_API_KEY=
# HF_TOKEN=
# Amazon Bedrock uses SigV4, not a bearer key (probe is config-only):
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# Local open-weight families (Phi-4 / Gemma 3 / Llama 4 / Qwen 3) route through
# an OpenAI-compatible runtime — no key; run e.g. Ollama at localhost:11434.
#
# Embeddings:
# VOYAGE_API_KEY=
#
# Vector / search stores:
# QDRANT_API_KEY=
# PINECONE_API_KEY=
# WEAVIATE_API_KEY=
# PGVECTOR_DSN=postgresql://user:pass@localhost:5432/vectors
# CASSANDRA_USERNAME=
# CASSANDRA_PASSWORD=
# OPENSEARCH_USERNAME=
# OPENSEARCH_PASSWORD=
#
# Data extraction (hosted APIs; self-hosted backends need only a base_url):
# FIRECRAWL_API_KEY=
# LLAMA_CLOUD_API_KEY=
