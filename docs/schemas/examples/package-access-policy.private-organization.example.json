{
  "apiVersion": "nexus.io/v1alpha2",
  "kind": "PackageAccessPolicy",
  "metadata": {
    "package": "acme-internal-playbooks",
    "version": "0.9.0"
  },
  "spec": {
    "visibility": "private-organization",
    "publisher_verification": "unverified",
    "license": "LicenseRef-Acme-Internal-1.0",
