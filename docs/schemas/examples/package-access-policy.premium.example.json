{
  "apiVersion": "nexus.io/v1alpha2",
  "kind": "PackageAccessPolicy",
  "metadata": {
    "package": "legal-vertical",
    "version": "2.1.0"
  },
  "spec": {
    "visibility": "verified-premium",
    "publisher_verification": "verified",
    "license": "LicenseRef-Ironbat-Commercial-1.0",
    "commercial_terms_ref": "https://nexusos.dev/terms/legal-vertical",
    "required_entitlements": ["premium_pack_access"],
    "required_scopes": ["verified-premium:legal-vertical"],
    "mirrorable": false,
    "requires_hub_account": true,
    "distribution": "short_lived_grant"
  }
}
