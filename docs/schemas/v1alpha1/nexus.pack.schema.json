{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.nexusos.dev/v1alpha1/nexus.pack.schema.json",
  "title": "nexus.pack.yaml (v1alpha1)",
  "description": "Manifest for a distributable Registry package (areas, agents, packs, flows, sidecars, skulls). TARGET-STATE contract. A pack COMPOSES existing Runtime primitives; it never ships a new runtime engine. Contains NO secret values and NO business data.",
  "x-nexus-contract-version": "v1alpha1",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "allOf": [
    {
      "$comment": "Restricted lanes must declare required entitlements. Backward compatible: packs without visibility (=public) are unaffected.",
      "if": {
        "properties": { "metadata": { "properties": { "visibility": { "enum": ["verified-premium", "private-organization"] } }, "required": ["visibility"] } }
      },
      "then": {
        "properties": { "spec": { "required": ["required_entitlements"], "properties": { "required_entitlements": { "minItems": 1 } } } }
      }
    }
  ],
  "properties": {
    "apiVersion": { "const": "nexus.io/v1alpha1" },
    "kind": { "const": "Pack" },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "publisher", "license"],
      "properties": {
        "name": { "$ref": "common.defs.schema.json#/$defs/Slug" },
        "display_name": { "type": "string" },
        "version": {
          "$ref": "common.defs.schema.json#/$defs/SemVer",
          "description": "Immutable once published; a new build requires a new version."
        },
        "publisher": {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "verification"],
          "properties": {
            "id": { "type": "string", "minLength": 1 },
            "display_name": { "type": "string" },
            "verification": {
              "type": "string",
              "enum": ["verified", "community", "official"],
              "description": "Curation status shown in the catalogue. `official` marks Ironbat-published packs. Additive over the original two-state set (backward compatible). See v1alpha2 PublisherVerification and ADR-0006."
            }
          }
        },
        "license": {
          "$ref": "common.defs.schema.json#/$defs/SpdxLicense",
          "description": "REQUIRED SPDX license expression of the pack CONTENT. A pack may be Apache/community, commercial/proprietary (LicenseRef-...), or another declared compatible license. This grants no rights over NexusOS/Ironbat trademarks (see 'trademark')."
        },
        "visibility": {
          "type": "string",
          "enum": ["public", "community", "verified-premium", "private-organization"],
          "description": "OPTIONAL Registry distribution lane (additive over v1alpha1). Full access semantics live in v1alpha2/package-access-policy. public/community are OSS and mirrorable without a Hub account; verified-premium/private-organization require an entitlement scope and a short-lived download grant (never DRM). Absent means public."
        },
        "commercial_terms_ref": {
          "type": "string",
          "description": "OPTIONAL reference to external commercial terms when the pack is not purely OSS. Never embeds the terms themselves."
        },
        "trademark": {
          "type": "object",
          "additionalProperties": false,
          "description": "Clarifies that the content license does NOT convey NexusOS/Ironbat brand rights. Trademark policy is governed separately from the code/content license (ADR-0008).",
          "properties": {
            "notice": { "type": "string", "description": "e.g. 'NexusOS and Ironbat are trademarks of Ironbat Digital LLC; this license grants no trademark rights.'" },
            "policy_url": { "type": "string", "description": "Link to the separate trademark policy." }
          }
        },
        "signature": {
          "description": "Primary publication signature. Registry-published packs use sigstore-cosign (keyless OIDC + transparency log); the field also accepts ed25519 for privately distributed packs.",
          "$ref": "common.defs.schema.json#/$defs/Signature"
        },
        "offline_signature": {
          "description": "Optional secondary signature for air-gapped/self-hosted verification without Sigstore infrastructure. Constrained to minisign or ed25519.",
          "allOf": [
            { "$ref": "common.defs.schema.json#/$defs/Signature" },
            { "properties": { "algorithm": { "enum": ["minisign", "ed25519"] } } }
          ]
        },
        "provenance": {
          "type": "object",
          "additionalProperties": false,
          "description": "Public supply-chain provenance for the published artifact (Sigstore bundle + SBOM attestation). Public metadata only.",
          "properties": {
            "sigstore_bundle_ref": { "type": "string", "description": "Reference to the .sigstore bundle (cert + signature + inclusion proof)." },
            "transparency": { "$ref": "common.defs.schema.json#/$defs/TransparencyLogEntry" },
            "sbom_attestation_ref": { "type": "string", "description": "Reference to the signed SBOM attestation." }
          }
        }
      }
    },
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["compatibility", "uninstall"],
      "properties": {
        "kind_hint": {
          "type": "string",
          "enum": ["area", "agent", "flow", "sidecar", "skull", "vertical"],
          "description": "Primary artifact the pack centres on; a vertical pack composes several."
        },
        "required_entitlements": {
          "type": "array",
          "description": "OPTIONAL capability identifiers the installing instance must hold to install/run this pack (additive over v1alpha1). MUST be present and non-empty when metadata.visibility is verified-premium/private-organization. Stable, plan-independent ids (e.g. 'premium_pack_access').",
          "items": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]*$",
            "minLength": 2,
            "maxLength": 64
          },
          "uniqueItems": true
        },
        "compatibility": {
          "type": "object",
          "additionalProperties": false,
          "required": ["runtime"],
          "properties": {
            "runtime": { "$ref": "common.defs.schema.json#/$defs/SemVerRange" },
            "operator": { "$ref": "common.defs.schema.json#/$defs/SemVerRange" }
          }
        },
        "dependencies": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "version"],
            "properties": {
              "name": { "$ref": "common.defs.schema.json#/$defs/Slug" },
              "version": { "$ref": "common.defs.schema.json#/$defs/SemVerRange" }
            }
          }
        },
        "permissions": {
          "type": "array",
          "description": "Accesses, tools or data scopes the pack requests at install time.",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["scope", "reason"],
            "properties": {
              "scope": { "type": "string" },
              "reason": { "type": "string" }
            }
          }
        },
        "resources": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "cpu_hint": { "type": "string" },
            "memory_hint": { "type": "string" },
            "cost_hint": { "type": "string" }
          }
        },
        "areas": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["slug", "label"],
            "properties": {
              "slug": { "$ref": "common.defs.schema.json#/$defs/Slug" },
              "label": { "type": "string" },
              "coordinator": { "$ref": "common.defs.schema.json#/$defs/Slug" }
            }
          }
        },
        "agents": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id"],
            "properties": {
              "id": { "$ref": "common.defs.schema.json#/$defs/Slug" },
              "artifact_type": { "type": "string", "enum": ["agent", "sidecar", "skill"] },
              "area": { "$ref": "common.defs.schema.json#/$defs/Slug" },
              "cognition_profile": { "$ref": "common.defs.schema.json#/$defs/Slug" }
            }
          }
        },
        "flows": {
          "type": "array",
          "items": { "$ref": "common.defs.schema.json#/$defs/Slug" }
        },
        "sidecars": {
          "type": "array",
          "items": { "$ref": "common.defs.schema.json#/$defs/Slug" }
        },
        "skulls": {
          "type": "array",
          "description": "Agent Cognition Profiles shipped by the pack. Never contain business data or secrets.",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id"],
            "properties": {
              "id": { "$ref": "common.defs.schema.json#/$defs/Slug" },
              "model_policy": { "type": "string" },
              "eval_suite": { "type": "string" }
            }
          }
        },
        "default_mappings": {
          "type": "object",
          "description": "Suggested install-time configuration (default roles, initial autonomy).",
          "additionalProperties": true
        },
        "migrations": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id"],
            "properties": {
              "id": { "type": "string" },
              "description": { "type": "string" },
              "reversible": { "type": "boolean", "default": true }
            }
          }
        },
        "tests": {
          "type": "array",
          "description": "Validation suite the pack must pass against the real instance before activation.",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id"],
            "properties": {
              "id": { "type": "string" },
              "description": { "type": "string" }
            }
          }
        },
        "uninstall": {
          "type": "object",
          "additionalProperties": false,
          "required": ["strategy"],
          "description": "Inverse procedure. NOT optional.",
          "properties": {
            "strategy": { "type": "string", "enum": ["reverse_migrations", "remove_only", "custom"] },
            "notes": { "type": "string" }
          }
        },
        "sbom": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "format": { "type": "string", "enum": ["cyclonedx", "spdx"] },
            "ref": { "type": "string" }
          }
        }
      }
    }
  }
}
